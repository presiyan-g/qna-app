# Seeding the database
# Required to run `npm run seed`. Single explicit opt-in so the command can't run by accident.
ALLOW_SEED=

# Neon serverless Postgres connection string.
# Get this from the Neon console: https://console.neon.tech
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=
# Secret used to sign JWTs. Generate a long random value (e.g. `openssl rand -base64 48`).
JWT_SECRET=

# Cloudflare R2 (S3-compatible) image uploads.
# Endpoint is from the R2 dashboard "Account ID" page: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Bucket name (lowercase, no slashes).
R2_BUCKET=
# Public read URL prefix (enable "Public access" on the bucket in R2, then copy the pub-*.r2.dev URL,
# or a custom domain). Used to build URLs stored in the database.
R2_PUBLIC_URL=
# R2 API token credentials (Manage R2 API Tokens → Create API Token, scoped to this bucket).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# OpenRouter — AI question draft generation.
# Sign up at https://openrouter.ai and create an API key (settings → Keys).
OPENROUTER_API_KEY=
# Optional. Defaults to https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=
# Model slug used for AI question drafts. Defaults to google/gemini-2.5-flash-lite.
# Swap to openai/gpt-4o-mini or anthropic/claude-haiku-4-5 if drafts feel formulaic.
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Daily per-user cap on successful AI draft generations (UTC day).
AI_DAILY_QUOTA=20
# Max output tokens per AI call.
AI_MAX_OUTPUT_TOKENS=800
# Per-call request timeout in ms.
AI_REQUEST_TIMEOUT_MS=20000
# Per-user cooldown in ms between successful AI calls.
AI_COOLDOWN_MS=5000
