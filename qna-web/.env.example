# Neon serverless Postgres connection string.
# Get this from the Neon console: https://console.neon.tech
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=
# Secret used to sign JWTs. Generate a long random value (e.g. `openssl rand -base64 48`).
JWT_SECRET=

# Cloudflare R2 (S3-compatible) image uploads.
# Endpoint is from the R2 dashboard "Account ID" page: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Bucket name (lowercase, no slashes).
R2_BUCKET=
# Public read URL prefix (enable "Public access" on the bucket in R2, then copy the pub-*.r2.dev URL,
# or a custom domain). Used to build URLs stored in the database.
R2_PUBLIC_URL=
# R2 API token credentials (Manage R2 API Tokens → Create API Token, scoped to this bucket).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
